# AI Service Environment Variables
AI_SERVICE_PORT=8000

# UPGRADED: Changed default from 'phi' to 'mistral' for better quality
# Mistral: Excellent reasoning, 7B model, balanced speed/quality
# Other options: neural-chat (faster), llama2:13b (more capable), dolphin-mixtral (specialized)
OLLAMA_MODEL_NAME=mistral

# Optional: GPU Configuration (dramatically speeds up inference)
# Set to true if you have CUDA/GPU available
OLLAMA_GPU=false

# Service URLs
BACKEND_URL=http://localhost:5000

